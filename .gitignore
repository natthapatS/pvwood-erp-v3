# ── Secrets / local config ───────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── Databases / dumps (never commit data) ────────────────
*.db
*.sqlite
*.sqlite3
*.dump
*.sql.gz

# ── Editor / OS ──────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
# Office/Excel lock files
~$*

# ── Generated ────────────────────────────────────────────
/exports/

# ── Workbooks (regenerate blanks via scripts/build_templates.py; filled data
#    stays local, out of git) ──
/templates/*.xlsx
