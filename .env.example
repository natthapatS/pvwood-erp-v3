# Copy to `.env` (gitignored) and fill in real values.

APP_ENV=dev
APP_NAME=PVWood ERP v3

# ── Database ─────────────────────────────────────────────
# Option A — full SQLAlchemy URL (takes precedence if set):
# DATABASE_URL=postgresql+psycopg://pvwood:CHANGEME@127.0.0.1:5432/pvwood_v3_dev

# Option B — discrete parts (used when DATABASE_URL is unset):
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=pvwood_v3_dev
PG_USER=pvwood
PG_PASSWORD=
# prefer | require | disable — 'require' when reaching the DB offsite/over the network
PG_SSLMODE=prefer

# Log every SQL statement (dev debugging only)
SQL_ECHO=false
